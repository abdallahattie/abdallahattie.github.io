---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { PROFILE, SOCIALS } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <canvas id="constellation" aria-hidden="true"></canvas>
    <div class="glow green" aria-hidden="true"></div>
    <div class="glow blue" aria-hidden="true"></div>
    <div class="inner">
      <p class="eyebrow">{PROFILE.eyebrow}</p>
      <h1>{PROFILE.name}</h1>
      <p class="headline">
        {PROFILE.headlineStatic}
        <span class="rotator" id="rotator">{PROFILE.headlineWords[0]}</span>.
      </p>
      <p class="tagline">{PROFILE.tagline}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/blog/">Read the blog</a>
        <a class="btn btn-ghost" href="#contact">Get in touch</a>
      </div>
      <div class="terminal" aria-hidden="true">
        <span class="prompt">$</span> {PROFILE.terminal.command}<br />
        <span class="out">{PROFILE.terminal.output}</span> <span class="cursor"></span>
      </div>
    </div>
  </section>

  <div class="container">
    <section class="block reveal">
      <p class="eyebrow">Signal, not noise</p>
      <div class="section-title"><h2>About</h2></div>
      {PROFILE.about.map((paragraph) => <p class="lede">{paragraph}</p>)}
    </section>

    <section class="block reveal">
      <p class="eyebrow">Operating principles</p>
      <div class="section-title"><h2>How I think</h2></div>
      <div class="cards">
        {
          PROFILE.principles.map((p) => (
            <div class="card">
              <span class="num">{p.n}</span>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="block reveal">
      <p class="eyebrow">From the blog</p>
      <div class="section-title">
        <h2>Latest writing</h2>
        <a class="more" href="/blog/">All posts →</a>
      </div>
      <ul class="post-list">
        {
          posts.map((post) => (
            <li>
              <a class="post-title" href={`/blog/${post.id}/`}>
                {post.data.title}
              </a>
              <p class="post-meta">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="block reveal" id="contact">
      <p class="eyebrow">Open channel</p>
      <div class="section-title"><h2>Get in touch</h2></div>
      <p class="lede">
        Building something ambitious, or thinking about what AI could do for
        your company? The best way to reach me is by email — I read
        everything.
      </p>
      <ul class="contact-links">
        {
          SOCIALS.map((s) => (
            <li>
              <span class="label">{s.label}</span>
              <a href={s.href}>{s.handle}</a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<script>
  // Rotating headline word — crossfade on the contemplative scale.
  import { PROFILE } from '../consts';

  const rotator = document.getElementById('rotator');
  const words = PROFILE.headlineWords;
  if (rotator && words.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let i = 0;
    setInterval(() => {
      rotator.classList.add('swap');
      setTimeout(() => {
        i = (i + 1) % words.length;
        rotator.textContent = words[i];
        rotator.classList.remove('swap');
      }, 380);
    }, 3400);
  }

  // Particle constellation — slow-drifting nodes, linked when close.
  const canvas = document.getElementById('constellation') as HTMLCanvasElement | null;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (canvas && !reduced) {
    const ctx = canvas.getContext('2d')!;
    const COLORS = ['rgba(64,153,240,', 'rgba(98,193,140,', 'rgba(0,212,255,'];
    let w = 0;
    let h = 0;
    let dpr = 1;
    type Node = { x: number; y: number; vx: number; vy: number; r: number; c: string };
    let nodes: Node[] = [];

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = canvas!.offsetWidth;
      h = canvas!.offsetHeight;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(90, Math.floor((w * h) / 16000));
      nodes = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.22,
        vy: (Math.random() - 0.5) * 0.22,
        r: 1 + Math.random() * 1.6,
        c: COLORS[Math.floor(Math.random() * COLORS.length)],
      }));
    }

    function step() {
      ctx.clearRect(0, 0, w, h);
      const LINK = 120;
      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < -10) n.x = w + 10;
        if (n.x > w + 10) n.x = -10;
        if (n.y < -10) n.y = h + 10;
        if (n.y > h + 10) n.y = -10;
      }
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i];
          const b = nodes[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < LINK * LINK) {
            const alpha = 0.14 * (1 - Math.sqrt(d2) / LINK);
            ctx.strokeStyle = `rgba(128,189,248,${alpha.toFixed(3)})`;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }
      for (const n of nodes) {
        ctx.fillStyle = `${n.c}0.55)`;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }
      requestAnimationFrame(step);
    }

    resize();
    window.addEventListener('resize', resize);
    document.fonts?.ready.then(() => resize());
    requestAnimationFrame(step);
  }
</script>
