---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { PROFILE, SOCIALS } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <div class="orb ocean" data-parallax="0.18" aria-hidden="true"></div>
    <div class="orb coral" data-parallax="0.28" aria-hidden="true"></div>
    <div class="orb aqua" data-parallax="0.12" aria-hidden="true"></div>
    <div class="orb indigo" data-parallax="0.22" aria-hidden="true"></div>
    <div class="blob b1" data-parallax="0.1" aria-hidden="true"></div>
    <div class="blob b2" data-parallax="0.16" aria-hidden="true"></div>
    <div class="inner">
      <div>
        <p class="eyebrow rise d1">{PROFILE.eyebrow}</p>
        <h1 class="rise d2">{PROFILE.name}</h1>
        <p class="headline rise d3">
          {PROFILE.headlineStatic}
          <span class="rotator" id="rotator">{PROFILE.headlineWords[0]}</span>.
        </p>
        <p class="tagline rise d3">{PROFILE.tagline}</p>
        <div class="cta-row rise d4">
          <a class="btn btn-primary" href="/blog/">Read the blog</a>
          <a class="btn btn-ghost" href="#contact">Get in touch</a>
        </div>
        <div class="terminal rise d5" aria-hidden="true">
          <span class="prompt">$</span> {PROFILE.terminal.command}<br />
          <span class="out">{PROFILE.terminal.output}</span> <span class="cursor"></span>
        </div>
      </div>
      <div class="portrait-col rise d2">
        <div class="portrait">
          <img src={PROFILE.photo} alt={`Portrait of ${PROFILE.name}`} width="240" height="240" />
        </div>
      </div>
    </div>
  </section>

  <svg
    class="wave-divider"
    viewBox="0 0 1440 90"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      fill="currentColor"
      opacity="0.35"
      d="M0,48 C240,90 480,6 720,30 C960,54 1200,84 1440,42 L1440,90 L0,90 Z"
    ></path>
    <path
      fill="currentColor"
      opacity="0.6"
      d="M0,66 C260,30 520,84 780,60 C1040,36 1260,66 1440,60 L1440,90 L0,90 Z"
    ></path>
  </svg>

  <div class="container">
    <section class="block reveal">
      <p class="eyebrow">Signal, not noise</p>
      <div class="section-title"><h2>About</h2></div>
      {PROFILE.about.map((paragraph) => <p class="lede">{paragraph}</p>)}
    </section>

    <section class="block">
      <div class="reveal">
        <p class="eyebrow">Operating principles</p>
        <div class="section-title"><h2>How I think</h2></div>
      </div>
      <div class="cards">
        {
          PROFILE.principles.map((p, i) => (
            <div class="card reveal" style={`--reveal-delay: ${i * 130}ms`}>
              <span class="num">{p.n}</span>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="block">
      <div class="reveal">
        <p class="eyebrow">From the blog</p>
        <div class="section-title">
          <h2>Latest writing</h2>
          <a class="more" href="/blog/">All posts →</a>
        </div>
      </div>
      <ul class="post-list">
        {
          posts.map((post, i) => (
            <li class="reveal" style={`--reveal-delay: ${i * 130}ms`}>
              <a class="post-title" href={`/blog/${post.id}/`}>
                {post.data.title}
              </a>
              <p class="post-meta">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="block reveal" id="contact">
      <p class="eyebrow">Open channel</p>
      <div class="section-title"><h2>Get in touch</h2></div>
      <p class="lede">
        Building something ambitious, or thinking about what AI could do for
        your company? The best way to reach me is by email — I read
        everything.
      </p>
      <ul class="contact-links">
        {
          SOCIALS.map((s) => (
            <li>
              <span class="label">{s.label}</span>
              <a href={s.href}>{s.handle}</a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<script>
  // Rotating headline word — gentle crossfade.
  import { PROFILE } from '../consts';

  const rotator = document.getElementById('rotator');
  const words = PROFILE.headlineWords;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (rotator && words.length > 1 && !reduced) {
    let i = 0;
    setInterval(() => {
      rotator.classList.add('swap');
      setTimeout(() => {
        i = (i + 1) % words.length;
        rotator.textContent = words[i];
        rotator.classList.remove('swap');
      }, 340);
    }, 3400);
  }

  // Parallax — orbs and blobs glide slower than the scroll.
  const layers = Array.from(
    document.querySelectorAll<HTMLElement>('[data-parallax]')
  );
  if (layers.length && !reduced) {
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      for (const el of layers) {
        const speed = Number(el.dataset.parallax) || 0.15;
        el.style.translate = `0 ${y * speed}px`;
      }
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true }
    );
  }
</script>
